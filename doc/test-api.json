// 定义必需的查询参数字段
const requiredFields = [
    'startDate',
    'endDate',
    'comparisonStartDate',
    'comparisonEndDate',
    'userPromt'
];

// 获取输入数据 (n8n Code 节点的标准输入对象)
const inputData = $input.all(); // 获取所有输入项
// 通常 HTTP Request 触发器的数据在第一个输入项的 json 属性中
const httpRequestData = inputData[0].json;

// 从 query 对象中提取字段
const queryData = httpRequestData.query || {};

// 检查必需字段
const missingFields = [];
for (const field of requiredFields) {
    if (!(field in queryData) || queryData[field] === undefined || queryData[field] === null || queryData[field] === '') {
        missingFields.push(field);
    }
}

// 如果有缺失字段，返回失败信息
if (missingFields.length > 0) {
    const errorMessage = `Missing required fields in query parameters: ${missingFields.join(', ')}`;
    // 返回失败的 JSON 结构，不抛出异常
    return {
        json: {
            success: false,
            error: errorMessage,
            missingFields: missingFields,
            receivedQuery: queryData // 可选：返回接收到的查询参数以便调试
        }
    };
}

// 如果所有必需字段都存在，继续执行后续逻辑或返回成功信息
// console.log("All required date fields are present:", queryData);
return {
    json: {
        success: true,
        message: "All required date fields are present.",
        queryParameters: queryData // 可以将解析后的参数传递给下一个节点
    }
};