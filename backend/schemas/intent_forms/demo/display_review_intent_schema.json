{
  "type": "form",
  "mode": "horizontal",
  "wrapWithPanel": false,
  "body": [
    {
      "type": "input-date",
      "name": "startDate",
      "label": "开始日期",
      "format": "YYYY-MM-DD",
      "required": true
    },
    {
      "type": "input-date",
      "name": "endDate",
      "label": "结束日期",
      "format": "YYYY-MM-DD",
      "required": true
    },
    {
      "type": "input-date",
      "name": "comparisonStartDate",
      "label": "对比开始日期",
      "format": "YYYY-MM-DD",
      "required": true
    },
    {
      "type": "input-date",
      "name": "comparisonEndDate",
      "label": "对比结束日期",
      "format": "YYYY-MM-DD",
      "required": true
    },
    {
      "type": "input-text",
      "name": "userPromt",
      "label": "用户提示",
      "required": true
    }
  ]
}