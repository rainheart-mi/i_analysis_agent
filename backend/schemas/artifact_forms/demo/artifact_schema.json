{
  "type": "service",
  "body": [
    {
      "type": "grid",
      "columns": [
        {
          "body": [
            {
              "type": "tpl",
              "tpl": "<div style=\"background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);padding:20px;border-radius:12px;color:#fff;text-align:center\"><div style=\"font-size:12px;opacity:0.9;margin-bottom:8px\">汇总指标</div><div style=\"font-size:32px;font-weight:700\">${summary_metrics.0.value}</div></div>"
            }
          ]
        },
        {
          "body": [
            {
              "type": "tpl",
              "tpl": "<div style=\"background:linear-gradient(135deg,#48c6ef 0%,#6f86d6 100%);padding:20px;border-radius:12px;color:#fff;text-align:center\"><div style=\"font-size:12px;opacity:0.9;margin-bottom:8px\">销售达成100%</div><div style=\"font-size:32px;font-weight:700\">${summary_metrics.1.value}</div></div>"
            }
          ]
        },
        {
          "body": [
            {
              "type": "tpl",
              "tpl": "<div style=\"background:linear-gradient(135deg,#f093fb 0%,#f5576c 100%);padding:20px;border-radius:12px;color:#fff;text-align:center\"><div style=\"font-size:12px;opacity:0.9;margin-bottom:8px\">达成率均值</div><div style=\"font-size:32px;font-weight:700\">${summary_metrics.2.value}</div></div>"
            }
          ]
        },
        {
          "body": [
            {
              "type": "tpl",
              "tpl": "<div style=\"background:linear-gradient(135deg,#ff9a9e 0%,#fecfef 100%);padding:20px;border-radius:12px;color:#fff;text-align:center\"><div style=\"font-size:12px;opacity:0.9;margin-bottom:8px\">待提升品类</div><div style=\"font-size:32px;font-weight:700\">${summary_metrics.3.value}</div></div>"
            }
          ]
        }
      ]
    },
    {
      "type": "table",
      "label": "表1：大类销售额/毛利额预算达成情况",
      "source": "${sales_report}",
      "columns": [
        { "label": "排名", "name": "rank", "width": 60 },
        { "label": "大类", "name": "category" },
        { "label": "销售实际", "name": "sales_actual", "type": "number" },
        { "label": "销售预算", "name": "sales_budget", "type": "number" },
        { "label": "销售达成率", "name": "sales_rate", "type": "number" },
        { "label": "毛利实际", "name": "profit_actual", "type": "number" },
        { "label": "毛利预算", "name": "profit_budget", "type": "number" },
        { "label": "毛利达成率", "name": "profit_rate", "type": "number" }
      ]
    },
    {
      "type": "table",
      "label": "表2：大类周环比趋势",
      "source": "${weekly_trend}",
      "columns": [
        { "label": "大类", "name": "category" },
        { "label": "周期", "name": "period" },
        { "label": "周销售额", "name": "sales", "type": "number" },
        { "label": "环比", "name": "trend" }
      ]
    },
    {
      "type": "list",
      "label": "关键洞察",
      "source": "${insights}",
      "listItem": {
        "body": [
          { "type": "tpl", "tpl": "${item}" }
        ]
      }
    }
  ]
}